[Unit]
Description=HH AutoPilot API
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/var/www/plat3/hh/api
Environment="PATH=/var/www/plat3/hh/api/venv/bin"
ExecStart=/var/www/plat3/hh/api/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8001
Restart=on-failure

[Install]
WantedBy=multi-user.target
