{
  "manifest_version": 3,
  "name": "HH AutoPilot — Автоотклик на вакансии",
  "version": "2.0.0",
  "description": "Автоматические отклики на hh.ru с AI-сопроводительными письмами. Работает через klikbot.ru",
  "permissions": ["tabs", "storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://hh.ru/*",
    "https://*.hh.ru/*",
    "https://klikbot.ru/*",
    "https://*.klikbot.ru/*",
    "http://localhost:5173/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://hh.ru/vacancy/*", "https://*.hh.ru/vacancy/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://klikbot.ru/*", "https://www.klikbot.ru/*", "http://localhost:5173/*"],
      "js": ["bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
